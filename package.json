{
  "name": "lunchmeet",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "expo:url": "node scripts/expo-url.js",
    "expo:qr": "node scripts/expo-qr.js",
    "expo:link-server": "node scripts/serve-expo-link.js",
    "start:console": "powershell -ExecutionPolicy Bypass -NoExit -File ./scripts/start-expo-console.ps1",
    "start-mobile": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile.ps1",
    "start-remote": "powershell -ExecutionPolicy Bypass -File ./scripts/start-remote.ps1",
    "start-remote:ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/start-remote-ngrok.ps1",
    "start-remote:cloudflare": "powershell -ExecutionPolicy Bypass -File ./scripts/start-remote-cloudflare.ps1",
    "start-remote:cf": "powershell -ExecutionPolicy Bypass -File ./scripts/start-remote-cf.ps1",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "proxy": "node server/places-proxy.js",
    "proxy:tunnel": "npx ngrok http 8787",
    "proxy:tunnel:lt": "npx localtunnel --port 8787",
    "restart-proxy": "npx kill-port 8787 && node server/places-proxy.js",
    "setup:eas-secrets": "node scripts/setup-eas-secrets.js",
    "build:android": "eas build --profile development --platform android",
    "build:android:standalone": "eas build --profile preview --platform android",
    "build:ios": "eas build --profile development --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:preview": "eas build --profile preview --platform all"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-google-maps/api": "^2.20.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@supabase/supabase-js": "^2.87.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.12",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "cloudflared": "^0.7.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "http-proxy": "^1.18.1",
    "qrcode": "^1.5.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
